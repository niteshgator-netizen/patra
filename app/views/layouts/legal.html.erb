<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= yield :title %> — Patra</title>
  <meta name="description" content="<%= yield :description %>">
  <meta name="robots" content="index, follow">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { font-size: 16px; -webkit-text-size-adjust: 100%; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      color: #1f2937;
      background: #ffffff;
      line-height: 1.6;
    }
    a { color: #6366f1; text-decoration: none; }
    a:hover { text-decoration: underline; }

    .nav {
      border-bottom: 1px solid #e5e7eb;
      padding: 16px 24px;
    }
    .nav-inner {
      max-width: 760px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between;
    }
    .brand {
      display: inline-flex; align-items: center; gap: 10px;
      font-weight: 700; font-size: 18px; color: #111827;
      letter-spacing: -0.01em;
    }
    .brand-mark {
      width: 28px; height: 28px; border-radius: 6px;
      background: #6366f1; color: #fff;
      display: inline-flex; align-items: center; justify-content: center;
      font-weight: 800; font-size: 16px;
    }
    .nav-links a { margin-left: 20px; font-size: 14px; color: #4b5563; }

    main {
      max-width: 760px; margin: 0 auto;
      padding: 48px 24px 80px;
    }
    h1 {
      font-size: 32px; font-weight: 700; letter-spacing: -0.02em;
      color: #111827; margin-bottom: 8px;
    }
    .subtitle { color: #6b7280; font-size: 14px; margin-bottom: 40px; }
    h2 {
      font-size: 18px; font-weight: 600; color: #111827;
      margin: 32px 0 12px; letter-spacing: -0.01em;
    }
    h3 {
      font-size: 15px; font-weight: 600; color: #374151;
      margin: 20px 0 8px;
    }
    p, ul, ol { margin-bottom: 14px; color: #374151; font-size: 15px; }
    ul, ol { padding-left: 22px; }
    li { margin-bottom: 6px; }
    strong { color: #111827; font-weight: 600; }

    .callout {
      background: #f5f3ff; border-left: 3px solid #6366f1;
      padding: 14px 16px; border-radius: 4px;
      margin: 16px 0; font-size: 14px; color: #312e81;
    }
    .contact-block {
      background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px;
      padding: 16px 20px; margin-top: 24px; font-size: 14px;
    }
    .contact-block strong { display: block; margin-bottom: 4px; color: #111827; }

    footer {
      border-top: 1px solid #e5e7eb; padding: 24px;
      color: #6b7280; font-size: 13px; text-align: center;
    }
    footer a { color: #6b7280; margin: 0 10px; }

    @media (max-width: 600px) {
      h1 { font-size: 26px; }
      main { padding: 32px 18px 60px; }
      .nav-links a { margin-left: 12px; }
    }
  </style>
</head>
<body>
  <header class="nav">
    <div class="nav-inner">
      <a href="/" class="brand">
        <span class="brand-mark">P</span>
        <span>Patra</span>
      </a>
      <nav class="nav-links">
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
      </nav>
    </div>
  </header>

  <main>
    <%= yield %>
  </main>

  <footer>
    &copy; <%= Date.current.year %> Patra
    &middot; <a href="/privacy">Privacy</a>
    &middot; <a href="/terms">Terms</a>
    &middot; <a href="mailto:support@patrahq.com">support@patrahq.com</a>
  </footer>
</body>
</html>
